@page
@using System.Text.Json
@model LibraryScanner.Web.Pages.Tags.IndexModel
@{
    ViewData["Title"] = "Tags";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Inventory labels</p>
        <h1>Tags</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Books/Index">Back</a>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<section class="panel">
    <h2>Search or create tags</h2>
    <form method="post" class="tag-admin-form" id="tag-create-form">
        <div class="tag-input-stack">
            <input asp-for="Input.Name" class="form-control" id="tag-search-input" placeholder="Search existing tags or create new ones with commas" autocomplete="off" />
            <div class="tag-search-results" id="tag-search-results" hidden></div>
            <span asp-validation-for="Input.Name" class="text-danger"></span>
            <span class="form-hint">Type to search live. Press Enter to create any tags that do not already exist.</span>
        </div>
        <input asp-for="Input.Description" class="form-control" placeholder="Optional tag note or meaning" />
        <input asp-for="Input.Color" class="form-control color-input" type="color" />
        <button asp-page-handler="Create" class="btn btn-primary">Create tags</button>
        <a class="btn btn-outline-secondary" asp-page="/Tags/Index">Clear</a>
    </form>
</section>

<div class="table-wrap">
    <table class="table inventory-table">
        <thead>
            <tr>
                <th>Tag</th>
                <th>Books</th>
                <th>Edit</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var tag in Model.Tags)
        {
            <tr id="tag-@tag.Id" data-tag-row data-tag-search="@($"{tag.Name} {tag.Description}".Trim())">
                <td>
                    <span class="tag-pill" style="--tag-color:@tag.Color">@tag.Name</span>
                    @if (!string.IsNullOrWhiteSpace(tag.Description))
                    {
                        <span class="muted-block">@tag.Description</span>
                    }
                </td>
                <td>@tag.BookCount</td>
                <td>
                    <form method="post" class="tag-edit-form">
                        <input name="id" type="hidden" value="@tag.Id" />
                        <input name="name" class="form-control" value="@tag.Name" />
                        <input name="description" class="form-control" value="@tag.Description" placeholder="Optional note" />
                        <input name="color" class="form-control color-input" type="color" value="@tag.Color" />
                        <button asp-page-handler="Update" class="btn btn-sm btn-outline-secondary">Save</button>
                    </form>
                </td>
                <td class="text-end">
                    <form method="post">
                        <input name="id" type="hidden" value="@tag.Id" />
                        <button asp-page-handler="Delete" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script id="tag-search-data" type="application/json">
@Html.Raw(JsonSerializer.Serialize(Model.Tags.Select(tag => new { tag.Id, tag.Name, tag.Description, tag.Color, tag.BookCount })))
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const input = document.getElementById("tag-search-input");
            const results = document.getElementById("tag-search-results");
            const rows = Array.from(document.querySelectorAll("[data-tag-row]"));
            const rawData = document.getElementById("tag-search-data")?.textContent ?? "[]";
            const tags = JSON.parse(rawData);

            if (!input || !results) {
                return;
            }

            const normalize = (value) => value.trim().replace(/\s+/g, " ").toUpperCase();
            const escapeHtml = (value) => String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");

            const getActiveToken = (value) => {
                const boundary = Math.max(value.lastIndexOf(","), value.lastIndexOf(";"));
                return value.slice(boundary + 1).trim();
            };

            const highlightRow = (id) => {
                rows.forEach((row) => row.classList.remove("tag-row-highlight"));
                const row = document.getElementById(`tag-${id}`);
                if (!row) {
                    return;
                }

                row.classList.add("tag-row-highlight");
                row.scrollIntoView({ behavior: "smooth", block: "center" });
            };

            const filterTable = (token) => {
                const query = normalize(token);
                rows.forEach((row) => {
                    const haystack = normalize(row.dataset.tagSearch ?? "");
                    row.hidden = query.length > 0 && !haystack.includes(query);
                });
            };

            const renderResults = () => {
                const token = getActiveToken(input.value);
                const query = normalize(token);
                const matchingTags = query.length === 0
                    ? tags.slice(0, 8)
                    : tags.filter((tag) => normalize(`${tag.name ?? tag.Name ?? ""} ${tag.description ?? tag.Description ?? ""}`).includes(query)).slice(0, 8);

                filterTable(token);

                if (matchingTags.length === 0 && query.length === 0) {
                    results.hidden = true;
                    results.innerHTML = "";
                    return;
                }

                const exactExists = query.length > 0 && tags.some((tag) => normalize(tag.name ?? tag.Name ?? "") === query);
                const items = matchingTags.map((tag) => {
                    const id = tag.id ?? tag.Id;
                    const name = tag.name ?? tag.Name;
                    const description = tag.description ?? tag.Description ?? "";
                    const color = tag.color ?? tag.Color ?? "#245f4c";
                    const bookCount = tag.bookCount ?? tag.BookCount ?? 0;
                    return `
                        <button type="button" class="tag-search-item" data-tag-id="${id}">
                            <span class="tag-pill" style="--tag-color:${escapeHtml(color)}">${escapeHtml(name)}</span>
                            <span class="tag-search-meta">${bookCount} book${bookCount === 1 ? "" : "s"}${description ? ` · ${escapeHtml(description)}` : ""}</span>
                        </button>`;
                });

                if (query.length > 0 && !exactExists) {
                    items.unshift(`
                        <div class="tag-search-create">
                            Press Enter to create: <strong>${escapeHtml(token)}</strong>
                        </div>`);
                }

                results.innerHTML = items.join("");
                results.hidden = false;

                results.querySelectorAll("[data-tag-id]").forEach((button) => {
                    button.addEventListener("click", () => {
                        highlightRow(button.dataset.tagId);
                    });
                });
            };

            input.addEventListener("input", renderResults);
            input.addEventListener("focus", renderResults);
            input.addEventListener("blur", () => {
                window.setTimeout(() => {
                    results.hidden = true;
                }, 120);
            });
        })();
    </script>
}
