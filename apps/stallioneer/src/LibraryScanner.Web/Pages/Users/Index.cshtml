@page "/Settings"
@model LibraryScanner.Web.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Control surface</p>
        <h1>Settings</h1>
        <p class="muted-block">Starter admin surface for Stallioneer. Right now it shows the local account records from <code>app.db</code>, and we can grow it into a fuller settings page later.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

@if (Model.IsAdmin)
{
    <section class="stats-grid compact-stats-grid">
        <div class="stat">
            <span class="stat-label">Total users</span>
            <strong>@Model.TotalUsers</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Confirmed emails</span>
            <strong>@Model.ConfirmedUsers</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Display names</span>
            <strong>@Model.NamedUsers</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Signed in as</span>
            <strong>@(Model.CurrentUser?.UserName ?? "Unknown")</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Admin users</span>
            <strong>@Model.AdminUsers</strong>
        </div>
    </section>
}

<section class="entry-grid">
    <section class="panel">
        <p class="eyebrow">Your profile</p>
        <h2>Signed-in account</h2>
        @if (Model.CurrentUser is null)
        {
            <p class="muted-block">No signed-in account could be resolved for this session.</p>
        }
        else
        {
            <form method="post" asp-page-handler="UpdateProfile" class="field-stack">
                <div>
                    <label>Username</label>
                    <input class="form-control" value="@Model.CurrentUser.UserName" readonly />
                </div>
                <div>
                    <label>Email</label>
                    <input class="form-control" value="@Model.CurrentUser.Email" readonly />
                </div>
                <div>
                    <label asp-for="Input.DisplayName">Display name</label>
                    <input asp-for="Input.DisplayName" class="form-control" autocomplete="nickname" />
                    <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                </div>
                <div>
                    <label>Email status</label>
                    <input class="form-control" value="@(Model.CurrentUser.EmailConfirmed ? "Confirmed" : "Unconfirmed")" readonly />
                </div>
                @if (Model.IsAdmin)
                {
                    <div>
                        <label>Permissions</label>
                        <input class="form-control" value="Admin" readonly />
                    </div>
                }
                @if (!Model.IsAdmin)
                {
                    <div>
                        <label>Library totals</label>
                        <p class="muted-block">
                            Titles: @Model.Snapshot.TotalBooks
                            <br />
                            Items: @Model.Snapshot.TotalItems
                            <br />
                            Tags: @Model.Snapshot.TotalTags
                            <br />
                            Collections: @Model.Snapshot.TotalCollections
                        </p>
                    </div>
                }
                <div class="lookup-actions">
                    <button type="submit" class="btn btn-primary">Save profile</button>
                </div>
            </form>
        }
    </section>

    @if (Model.IsAdmin)
    {
        <section class="panel">
            <p class="eyebrow">App snapshot</p>
            <h2>Local system</h2>
            <div class="field-stack">
                <div>
                    <label>Database path</label>
                    <input class="form-control" value="@Model.Snapshot.DatabasePath" readonly />
                </div>
                <div>
                    <label>Database updated</label>
                    <input class="form-control" value="@(Model.Snapshot.DatabaseLastUpdated?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Unknown")" readonly />
                </div>
                <div>
                    <label>Backup directory</label>
                    <input class="form-control" value="@Model.Snapshot.BackupDirectory" readonly />
                </div>
                <div>
                    <label>Latest backup</label>
                    <input class="form-control" value="@(Model.Snapshot.LatestBackupName ?? "No backup found")" readonly />
                </div>
                <div>
                    <label>Latest backup updated</label>
                    <input class="form-control" value="@(Model.Snapshot.LatestBackupUpdated?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Unknown")" readonly />
                </div>
            </div>
        </section>
    }
</section>

<section class="panel bulk-panel">
    <div class="bulk-copy">
        <p class="eyebrow">Data tools</p>
        <h2>Import / export</h2>
        <span class="form-hint">CSV uses Stallioneer's fixed common field set. PDF lets you choose which fields appear in a printable inventory report.</span>
    </div>
    <div class="import-export-grid">
        <form method="post" asp-page-handler="Export" class="inline-form">
            <div class="field-stack">
                <label>Export inventory</label>
                <span class="form-hint">Downloads the full library as CSV.</span>
            </div>
            <button type="submit" class="btn btn-outline-secondary">Export CSV</button>
        </form>

        <form method="post" asp-page-handler="Import" enctype="multipart/form-data" class="import-form">
            <div class="field-stack">
                <label asp-for="ImportFile">Import CSV</label>
                <input asp-for="ImportFile" type="file" accept=".csv,text/csv" class="form-control" />
                <span class="form-hint">New rows need ISBN-13 and title. Duplicate ISBN-13 rows inside the same file are skipped after the first match.</span>
            </div>
            <div class="field-stack">
                <label>Import mode</label>
                <label class="radio-line">
                    <input type="radio" asp-for="ImportMode" value="@LibraryScanner.Web.Pages.Users.IndexModel.ImportModes.MergeUpdate" checked />
                    <span>Append new books and update matching ISBN-13 records</span>
                </label>
                <label class="radio-line">
                    <input type="radio" asp-for="ImportMode" value="@LibraryScanner.Web.Pages.Users.IndexModel.ImportModes.AppendIgnore" />
                    <span>Append new books and ignore matching ISBN-13 records</span>
                </label>
                <label class="radio-line">
                    <input type="radio" asp-for="ImportMode" value="@LibraryScanner.Web.Pages.Users.IndexModel.ImportModes.Overwrite" />
                    <span>Overwrite book inventory with this CSV</span>
                </label>
                <span class="form-hint">Overwrite clears books, book tags, collection links, and inventory history before importing. Accounts and reusable tag/location/collection names remain.</span>
            </div>
            <button type="submit" class="btn btn-primary" onclick="return confirm('Import this CSV using the selected mode? Overwrite mode clears the current book inventory first.');">Import CSV</button>
        </form>

        <form method="post" asp-page-handler="ExportPdf" class="pdf-export-form">
            <div class="field-stack">
                <label>Export PDF fields</label>
                <div class="export-field-list">
                    @foreach (var field in Model.ExportFields)
                    {
                        var isChecked = LibraryScanner.Web.Services.InventoryExportField.DefaultPdfKeys.Contains(field.Key);
                        <label class="checkbox-pill">
                            <input type="checkbox" name="PdfFieldKeys" value="@field.Key" checked="@isChecked" />
                            <span>@field.Label</span>
                        </label>
                    }
                </div>
            </div>
            <button type="submit" class="btn btn-outline-secondary">Export PDF</button>
        </form>
    </div>
</section>

@if (Model.IsAdmin)
{
    <section class="panel">
        <p class="eyebrow">Admin tools</p>
        <h2>Account permissions</h2>
        <p class="muted-block">Use this section to decide which accounts can manage permissions and future system-wide settings. Stallioneer always keeps at least one admin account.</p>

        <div class="table-wrap">
            <table class="table inventory-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Display name</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Admin access</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td><strong>@user.UserName</strong></td>
                        <td>@(string.IsNullOrWhiteSpace(user.DisplayName) ? "-" : user.DisplayName)</td>
                        <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                        <td>@string.Join(", ", user.Roles)</td>
                        <td>
                            <form method="post" asp-page-handler="UpdatePermissions" class="inline-form">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="isAdmin" value="@(user.IsAdmin ? "false" : "true")" />
                                <span class="status-pill">@(user.IsAdmin ? "Admin" : "User")</span>
                                <button type="submit" class="btn btn-outline-secondary">
                                    @(user.IsAdmin ? "Remove admin" : "Make admin")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="stats-grid compact-stats-grid">
        <div class="stat">
            <span class="stat-label">Books</span>
            <strong>@Model.Snapshot.TotalBooks</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Items</span>
            <strong>@Model.Snapshot.TotalItems</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Tags</span>
            <strong>@Model.Snapshot.TotalTags</strong>
        </div>
        <div class="stat">
            <span class="stat-label">Collections</span>
            <strong>@Model.Snapshot.TotalCollections</strong>
        </div>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
