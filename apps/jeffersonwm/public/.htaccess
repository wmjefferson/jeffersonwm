RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect 4-character short URLs to perihelion share page
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9]{4})/?$ /perihelion/?share=$1 [R=302,L]

# Redirect root to /jeffersonwm (landing page)
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^(.*)$ /jeffersonwm/ [L]

# Jeffersonwm landing page SPA routing (if needed)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^jeffersonwm(/.*)?$ /jeffersonwm/index.html [L]

# Bullion app routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^bullion(/.*)?$ /bullion/index.html [L]

# Lionship app routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^lionship(/.*)?$ /lionship/index.html [L]

# Battalion app routing split
# 1. Serve landing.html at battalion root
RewriteCond %{REQUEST_URI} ^/battalion/?$
RewriteRule ^(.*)$ /battalion/landing.html [L]

# 2. Rewrite /battalion/home to index.html (the SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^battalion/home(/.*)?$ /battalion/index.html [L]

# 3. Rewrite any other battalion paths (deep links) to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^battalion(/.*)?$ /battalion/index.html [L]

# Perihelion app routing split
# 1. Redirect if a share query parameter is present (to bypass landing page)
RewriteCond %{QUERY_STRING} share=([a-zA-Z0-9]{4})
RewriteRule ^perihelion/?$ /perihelion/home [QSA,L,R=302]

# 2. Serve landing.html at perihelion root
RewriteCond %{REQUEST_URI} ^/perihelion/?$
RewriteRule ^(.*)$ /perihelion/landing.html [L]

# 3. Rewrite /perihelion/home to index.html (the SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^perihelion/home(/.*)?$ /perihelion/index.html [L]

# 4. Rewrite any other perihelion paths (deep links) to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^perihelion(/.*)?$ /perihelion/index.html [L]

# Clionidae app routing split
# 1. Serve landing.html at clionidae root
RewriteCond %{REQUEST_URI} ^/clionidae/?$
RewriteRule ^(.*)$ /clionidae/landing.html [L]

# 2. Rewrite /clionidae/home to index.html (the SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^clionidae/home(/.*)?$ /clionidae/index.html [L]

# 3. Rewrite any other clionidae paths (deep links) to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^clionidae(/.*)?$ /clionidae/index.html [L]

# Vermilion app routing split
# 1. Serve landing.html at vermilion root
RewriteCond %{REQUEST_URI} ^/vermilion/?$
RewriteRule ^(.*)$ /vermilion/landing.html [L]

# 2. Rewrite /vermilion/home to index.html (the SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^vermilion/home(/.*)?$ /vermilion/index.html [L]

# 3. Rewrite any other vermilion paths (deep links) to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^vermilion(/.*)?$ /vermilion/index.html [L]

# Millionfold app routing split
# 1. Serve landing.html at millionfold root
RewriteCond %{REQUEST_URI} ^/millionfold/?$
RewriteRule ^(.*)$ /millionfold/landing.html [L]

# 2. Rewrite /millionfold/home to index.html (the SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^millionfold/home(/.*)?$ /millionfold/index.html [L]

# 3. Rewrite any other millionfold paths (deep links) to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^millionfold(/.*)?$ /millionfold/index.html [L]

# Serve assets directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
